{
  "name": "ruyi-pos",
  "version": "1.0.0",
  "description": "如意收银 - 专业的零售级 POS 收银系统",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "npm run server-dev",
    "dev:daemon": "npm run server-dev:daemon",
    "dev:stop": "npm run server-dev:stop",
    "server-start": "npm start --prefix server",
    "server-dev": "npm run dev --prefix server",
    "server-dev:daemon": "npm run dev:daemon --prefix server",
    "server-dev:stop": "npm run dev:stop --prefix server",
    "rebuild:native": "electron-builder install-app-deps",
    "verify:sqlite": "node -e \"const Database=require('better-sqlite3'); const db=new Database(':memory:'); console.log(db.prepare('select 1 as ok').get()); db.close();\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "pos",
    "cashier",
    "retail",
    "ruyi"
  ],
  "author": "Ruyi POS Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.ruyipos.app",
    "productName": "如意收银系统",
    "copyright": "Copyright © 2026 Ruyi POS Team",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "npmRebuild": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "main.js",
      "preload.js",
      "preload-wizard.js",
      "index.html",
      "setup-wizard.html",
      "app.js",
      "styles.css",
      "server/**/*",
      "!server/node_modules/**/*",
      "!server/data.db",
      "!server/data.db-shm",
      "!server/data.db-wal",
      "!server/backups/**/*",
      "!server/d_/**/*",
      "assets/icon.ico",
      "LICENSE.txt"
    ],
    "extraResources": [
      {
        "from": "server/sqlite_schema.sql",
        "to": "server/sqlite_schema.sql"
      },
      {
        "from": "server/.env.example",
        "to": "server/.env.example"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "如意收银",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "license": "LICENSE.txt",
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName} ${version}.${ext}"
    }
  }
}
