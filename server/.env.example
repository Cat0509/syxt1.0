# SQLite database path (optional, defaults to Electron userData/RuyiPOS/data.db)
# DB_PATH=./data.db

# Server port
PORT=3000

# JWT secret (change this in production!)
JWT_SECRET=change_this_to_a_random_string

# HQ sync URL (optional, for multi-store mode)
# HQ_SYNC_URL=https://your-hq-server.com/api

# Sync interval in milliseconds (default: 30000)
# SYNC_INTERVAL_MS=30000
