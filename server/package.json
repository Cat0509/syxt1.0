{
    "name": "ruyi-pos-server",
    "version": "1.0.0",
    "description": "Backend for Ruyi POS cloud sync",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "dev": "nodemon index.js",
        "dev:daemon": "node scripts/dev-daemon.js",
        "dev:stop": "node scripts/dev-stop.js",
        "accept:phase3": "node scripts/phase3_acceptance_smoke.js",
        "accept:phase4": "node scripts/phase4_acceptance_smoke.js",
        "migrate:down": "node migrate.js --rollback",
        "migrate:up": "node migrate.js"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cors": "^2.8.5",
        "dotenv": "^17.2.4",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.3",
        "mysql2": "^3.16.3"
    },
    "devDependencies": {
        "nodemon": "^3.1.11"
    },
    "nodemonConfig": {
        "ignore": [
            "pos_data.json"
        ]
    }
}
